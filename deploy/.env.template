# .env.template for EC2 Bare-Metal Setup
SECRET_KEY=generate_a_secure_secret_key
DEBUG=False
FRONTEND_URL=https://lpcrm.yourdomain.com

# Local PostgreSQL
DATABASE_URL=postgresql://lpcrmuser:lpcrmpassword@localhost/lpcrm
DB_NAME=lpcrm

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=lpcrm-storage-prod
AWS_S3_REGION_NAME=us-east-1

# Meta Graph API
META_VERIFY_TOKEN=my_super_secret_verify_token_123
META_ACCESS_TOKEN=your_meta_access_token
