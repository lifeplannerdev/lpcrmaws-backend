[Unit]
Description=Celery Worker Service for lpcrm
After=network.target

[Service]
User=lpcrm
Group=www-data
WorkingDirectory=/home/lpcrm/lpcrmaws-backend
Environment="PATH=/home/lpcrm/lpcrmaws-backend/venv/bin"
EnvironmentFile=/home/lpcrm/lpcrmaws-backend/.env
ExecStart=/home/lpcrm/lpcrmaws-backend/venv/bin/celery -A lpcrm worker -l info

[Install]
WantedBy=multi-user.target
